# VK API token (get it via OAuth: https://dev.vk.com/)
VK_TOKEN=vk1.a.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Wall post with the poll (format: ownerID_postID)
VK_WALL_POST=-123456789_123

# Group ID (numeric, without minus)
VK_GROUP_ID=123456789

# Target city for geo analysis (lowercase)
VK_TARGET_CITY=киров
